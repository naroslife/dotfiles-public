# Backups
*.backup
*.backup-*

# IDE history
.history/

# Cache files
.cache/

# Build results
result
result-*

# Local configuration overrides
local.nix

# chezmoi machine-local data (per-machine secrets, not for VCS)
home/.chezmoidata/local.yaml

# Editor temporary files
*~
.*.swp
.*.swo

# OS files
.DS_Store
Thumbs.db

# Nix build outputs
.direnv/
*Zone.Identifier

# Serena configuration
# Keep the config template and project settings, but ignore dynamic files
# .serena/
# !.serena/serena_config.yml
# !.serena/project.yml

# Security: Never commit files with API keys or secrets
# Note: API keys should be in environment variables
*.key
*.secret
*secret*.json
*credential*.json
.env
.env.*
!.env.example

# Devenv
.devenv*
devenv.local.nix
devenv.local.yaml

# direnv
.direnv

# pre-commit
.pre-commit-config.yaml
home/dot_local/bin/__pycache__/
