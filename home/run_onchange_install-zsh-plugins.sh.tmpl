#!/usr/bin/env bash
# run_onchange_install-zsh-plugins.sh.tmpl
# chezmoi run_onchange_ script: executes when this file's content changes
# Installs Zsh plugins via git clone (no framework needed)
#
# Trigger hash (changes when plugin list changes):
# {{ include ".chezmoiexternal.toml" | sha256sum }}

set -euo pipefail

PLUGIN_DIR="${HOME}/.local/share/zsh/plugins"
mkdir -p "${PLUGIN_DIR}"

clone_or_update() {
  local repo="$1"
  local dest="${PLUGIN_DIR}/$(basename "${repo%.git}")"

  if [[ -d "${dest}/.git" ]]; then
    echo "Updating: ${dest}"
    git -C "${dest}" pull --quiet --ff-only
  else
    echo "Cloning: ${repo}"
    git clone --quiet --depth 1 "${repo}" "${dest}"
  fi
}

clone_or_update "https://github.com/zsh-users/zsh-autosuggestions.git"
clone_or_update "https://github.com/zsh-users/zsh-syntax-highlighting.git"
clone_or_update "https://github.com/Aloxaf/fzf-tab.git"

echo "Zsh plugins ready in ${PLUGIN_DIR}"
