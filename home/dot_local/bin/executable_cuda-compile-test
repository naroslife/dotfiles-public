#!/usr/bin/env bash
# cuda-compile-test — Compile and run the CUDA test program
# Source file: ~/.local/share/cuda/cuda-test.cu (managed by chezmoi)
# Managed by chezmoi — edit source at home/dot_local/bin/executable_cuda-compile-test

set -euo pipefail

GREEN='\033[0;32m'
RED='\033[0;31m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info()    { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }
log_error()   { echo -e "${RED}[ERROR]${NC} $1"; }

if ! command -v nvcc &>/dev/null; then
    log_error "nvcc not found — install CUDA: cuda-install"
    exit 1
fi

CUDA_DATA_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/cuda"
CUDA_TEST_SRC="$CUDA_DATA_DIR/cuda-test.cu"

if [[ ! -f "$CUDA_TEST_SRC" ]]; then
    log_error "CUDA test source not found: $CUDA_TEST_SRC"
    log_error "Ensure chezmoi has deployed the file: chezmoi apply"
    exit 1
fi

WORK_DIR=$(mktemp -d /tmp/cuda-compile-test-XXXXXX)
trap 'rm -rf "$WORK_DIR"' EXIT

cp "$CUDA_TEST_SRC" "$WORK_DIR/cuda-test.cu"
cd "$WORK_DIR"

log_info "Compiling CUDA test program..."
log_info "Using nvcc: $(command -v nvcc)"
log_info "CUDA version: $(nvcc --version | grep release | awk '{print $5}' | sed 's/,//')"

nvcc cuda-test.cu -o cuda-test

log_success "Compilation successful"
echo

log_info "Running CUDA test program..."
echo

./cuda-test
exit_code=$?

echo

if [[ $exit_code -eq 0 ]]; then
    log_success "All tests passed!"
else
    log_error "Some tests failed (exit code: $exit_code)"
fi

exit $exit_code
