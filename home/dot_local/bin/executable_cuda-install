#!/usr/bin/env bash
# cuda-install — Install and configure CUDA 12 toolkit on WSL2 Ubuntu
# Managed by chezmoi — edit source at home/dot_local/bin/executable_cuda-install

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info()    { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }
log_warning() { echo -e "${YELLOW}[WARNING]${NC} $1"; }
log_error()   { echo -e "${RED}[ERROR]${NC} $1"; }

check_wsl2() {
    local is_wsl2=false
    local detection_method=""

    if [[ -n "${WSL_DISTRO_NAME:-}" ]]; then
        is_wsl2=true
        detection_method="WSL_DISTRO_NAME environment variable"
    elif [[ -f /proc/sys/fs/binfmt_misc/WSLInterop ]]; then
        is_wsl2=true
        detection_method="WSLInterop file"
    elif [[ -f /proc/sys/fs/binfmt_misc/WSLInterop-late ]]; then
        is_wsl2=true
        detection_method="WSLInterop-late file (systemd enabled)"
    elif grep -qEi "(microsoft.*wsl2|wsl2)" /proc/version 2>/dev/null; then
        is_wsl2=true
        detection_method="kernel version"
    elif [[ -n "${WSL_INTEROP:-}" ]]; then
        is_wsl2=true
        detection_method="WSL_INTEROP environment variable"
    fi

    if [[ "$is_wsl2" == true ]]; then
        log_success "Running on WSL2 (detected via $detection_method)"
        return 0
    fi

    log_error "This script is designed for WSL2. Not running on WSL2."
    exit 1
}

readonly CUDA_VERSION="12.9"
readonly MIN_WINDOWS_DRIVER="528.33"

version_ge() {
    printf '%s\n%s\n' "$2" "$1" | sort -V -C 2>/dev/null
}

check_windows_driver() {
    log_info "Checking Windows NVIDIA driver compatibility with CUDA $CUDA_VERSION..."

    if [[ ! -f /mnt/c/Windows/System32/nvidia-smi.exe ]]; then
        log_error "Windows NVIDIA driver not found. Install NVIDIA drivers on Windows first."
        exit 1
    fi

    local driver_output
    driver_output=$(/mnt/c/Windows/System32/nvidia-smi.exe 2>&1 || true)

    if ! echo "$driver_output" | grep -q "Driver Version:"; then
        log_error "Windows NVIDIA driver not working properly"
        exit 1
    fi

    local driver_version
    driver_version=$(echo "$driver_output" | grep -oP 'Driver Version: \K[0-9.]+' | head -1)
    local cuda_version
    cuda_version=$(echo "$driver_output" | grep -oP 'CUDA Version: \K[0-9.]+' | head -1)

    log_success "Windows NVIDIA driver installed: $driver_version"
    log_info "Driver supports CUDA: $cuda_version"

    if ! version_ge "$driver_version" "$MIN_WINDOWS_DRIVER"; then
        log_error "Driver $driver_version does NOT support CUDA $CUDA_VERSION (min: $MIN_WINDOWS_DRIVER)"
        log_info "Update driver, then restart WSL: wsl --shutdown"
        log_info "Check requirements: cuda-check-driver"
        exit 1
    fi

    log_success "Driver supports CUDA $CUDA_VERSION"
    return 0
}

check_ubuntu_version() {
    log_info "Checking Ubuntu version..."

    if [[ ! -f /etc/lsb-release ]]; then
        log_error "Not running on Ubuntu"
        exit 1
    fi

    # shellcheck source=/dev/null
    source /etc/lsb-release
    log_success "Ubuntu $DISTRIB_RELEASE ($DISTRIB_CODENAME)"

    if [[ "$DISTRIB_RELEASE" != "22.04" ]] && [[ "$DISTRIB_RELEASE" != "20.04" ]]; then
        log_warning "This script is tested on Ubuntu 20.04 and 22.04 (yours: $DISTRIB_RELEASE)"
        read -r -p "Continue anyway? (y/N) " -n 1
        echo
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            exit 1
        fi
    fi
}

fix_nvidia_smi() {
    log_info "Checking nvidia-smi..."

    local wsl_nvidia_smi="/usr/lib/wsl/lib/nvidia-smi"

    if [[ -f "$wsl_nvidia_smi" ]] && [[ ! -L "$wsl_nvidia_smi" ]]; then
        if ! timeout 3 "$wsl_nvidia_smi" &>/dev/null; then
            log_warning "nvidia-smi segfaulting, replacing with Windows version"
            sudo mv "$wsl_nvidia_smi" "${wsl_nvidia_smi}.old"
            sudo ln -s /mnt/c/Windows/System32/nvidia-smi.exe "$wsl_nvidia_smi"
            log_success "Replaced nvidia-smi with Windows version"
        else
            log_success "nvidia-smi working correctly"
        fi
    elif [[ -L "$wsl_nvidia_smi" ]]; then
        log_success "nvidia-smi already configured as symlink"
    else
        log_info "Creating nvidia-smi symlink to Windows version"
        sudo mkdir -p /usr/lib/wsl/lib
        sudo ln -s /mnt/c/Windows/System32/nvidia-smi.exe "$wsl_nvidia_smi"
    fi
}

install_cuda_repo() {
    log_info "Installing CUDA repository..."

    local keyring_url="https://developer.download.nvidia.com/compute/cuda/repos/wsl-ubuntu/x86_64/cuda-keyring_1.1-1_all.deb"
    local keyring_deb="/tmp/cuda-keyring.deb"

    wget -q -O "$keyring_deb" "$keyring_url"
    sudo dpkg -i "$keyring_deb"
    rm "$keyring_deb"
    sudo apt-get update

    log_success "CUDA repository installed"
}

install_cuda_toolkit() {
    log_info "Installing CUDA 12.9 toolkit (this may take several minutes)..."

    sudo apt-get install -y \
        cuda-toolkit-12-9 \
        cuda-libraries-12-9 \
        cuda-libraries-dev-12-9

    log_success "CUDA toolkit installed"
}

configure_environment() {
    log_info "Configuring environment variables..."

    local shell_rc
    case "$(basename "$SHELL")" in
        zsh)  shell_rc="$HOME/.zshrc" ;;
        *)    shell_rc="$HOME/.bashrc" ;;
    esac

    if grep -q "# NVIDIA CUDA Configuration (added by cuda-install)" "$shell_rc" 2>/dev/null; then
        log_warning "CUDA configuration already exists in $shell_rc"
        return 0
    fi

    cat >> "$shell_rc" << 'EOF'

# NVIDIA CUDA Configuration (added by cuda-install)
export CUDA_HOME=/usr/local/cuda
export CUDA_PATH=/usr/local/cuda
export PATH=$CUDA_HOME/bin:$PATH
export LD_LIBRARY_PATH=/usr/lib/wsl/lib:$CUDA_HOME/lib64:${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}
EOF

    log_success "Environment variables added to $shell_rc"
    log_warning "Run 'source $shell_rc' or restart your shell to apply changes"
}

verify_installation() {
    log_info "Verifying installation..."

    export CUDA_HOME=/usr/local/cuda
    export CUDA_PATH=/usr/local/cuda
    export PATH=$CUDA_HOME/bin:$PATH
    export LD_LIBRARY_PATH=/usr/lib/wsl/lib:$CUDA_HOME/lib64:${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}

    if nvidia-smi &>/dev/null; then
        log_success "nvidia-smi working"
    else
        log_error "nvidia-smi not working"
        return 1
    fi

    if nvcc --version &>/dev/null; then
        local nvcc_version
        nvcc_version=$(nvcc --version | grep "release" | awk '{print $5}' | sed 's/,//')
        log_success "nvcc working (version $nvcc_version)"
    else
        log_error "nvcc not found"
        return 1
    fi

    log_success "Installation verified"
}

main() {
    log_info "Starting CUDA 12 installation for WSL2..."
    echo

    check_wsl2
    check_ubuntu_version
    check_windows_driver

    echo
    log_info "Ready to install CUDA 12.9 toolkit (~6.5GB)"
    read -r -p "Continue? (y/N) " -n 1
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        log_info "Installation cancelled"
        exit 0
    fi

    echo
    fix_nvidia_smi
    install_cuda_repo
    install_cuda_toolkit
    configure_environment

    echo
    verify_installation

    echo
    echo "=========================================="
    echo "CUDA Installation Complete!"
    echo "=========================================="
    echo
    echo "Next steps:"
    echo "  1. Restart your shell or run: source ~/.bashrc"
    echo "  2. Verify: cuda-test"
    echo "  3. Compile test: cuda-compile-test"
    echo
}

main "$@"
