# ~/.config/shell/aliases.sh — managed by chezmoi
# Shared shell aliases sourced by both .zshrc and .bashrc
# Edit source at home/dot_config/shell/aliases.sh.tmpl

# ── Kill switch ────────────────────────────────────────────────────────────────
# Touch ~/.config/shell/use-system-defaults to revert to plain system tools.
# Delete it (or run `dotfiles-modern`) to re-enable modern CLI replacements.
_KILL_SWITCH="${HOME}/.config/shell/use-system-defaults"
if [[ -f "${_KILL_SWITCH}" ]]; then
  unset -f cd 2>/dev/null || true
  unset _KILL_SWITCH
  return 0 2>/dev/null || exit 0
fi
unset _KILL_SWITCH

# ── Kill switch management ─────────────────────────────────────────────────────
alias dotfiles-classic='touch ~/.config/shell/use-system-defaults && exec $SHELL'
alias dotfiles-modern='rm -f ~/.config/shell/use-system-defaults && exec $SHELL'
alias dotfiles-status='[[ -f ~/.config/shell/use-system-defaults ]] && echo "Classic mode (system defaults)" || echo "Modern mode (enhanced tools)"'

# ── Modern CLI replacements ────────────────────────────────────────────────────
alias cat='bat'
alias ls='eza'
alias l='eza -l --icons --git -a'
alias lt='eza --tree --level=2 --long --icons --git'
alias ltree='eza --tree --level=2 --icons --git'
alias la='eza --tree --icons --git'
alias find='fd'
alias grep='rg'
alias df='duf'
alias du='dust'
alias ps='procs'
alias top='btm'
alias htop='btm'
alias ping='gping'
alias dig='dog'
alias http='xh'

# ── History tool switching ─────────────────────────────────────────────────────
# Requires switch_history function from ~/.local/share/shell-functions/
alias use-atuin='switch_history atuin'
alias use-mcfly='switch_history mcfly'
alias history-status='switch_history status'

# ── Git ───────────────────────────────────────────────────────────────────────
alias gc='git commit -m'
alias gca='git commit -a -m'
alias gp='git push origin HEAD'
alias gpu='git pull origin'
alias gst='git status'
alias glog='git log --graph --topo-order --pretty="%w(100,0,6)%C(yellow)%h%C(bold)%C(black)%d %C(cyan)%ar %C(green)%an%n%C(bold)%C(white)%s %N" --abbrev-commit'
alias gdiff='git diff'
alias gco='git checkout'
alias gb='git branch'
alias gba='git branch -a'
alias gadd='git add'
alias ga='git add -p'
alias gcoall='git checkout -- .'
alias gr='git remote'
alias gre='git reset'
alias gd='git diff'
alias gdt='git difftool'

# ── Docker ────────────────────────────────────────────────────────────────────
alias dco='docker compose'
alias dps='docker ps'
alias dpa='docker ps -a'
alias dl='docker ps -l -q'
alias dx='docker exec -it'

# ── Kubernetes ────────────────────────────────────────────────────────────────
alias k='kubectl'
alias ka='kubectl apply -f'
alias kg='kubectl get'
alias kd='kubectl describe'
alias kdel='kubectl delete'
alias kl='kubectl logs -f'
alias kgpo='kubectl get pod'
alias kgd='kubectl get deployments'
alias kc='kubectx'
alias ke='kubectl exec -it'
alias kcns='kubectl config set-context --current --namespace'

# ── Navigation ────────────────────────────────────────────────────────────────
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias .....='cd ../../../..'
alias ......='cd ../../../../..'
alias cl='clear'
alias v='nvim'
alias rr='ranger'
alias nm='nmap -sC -sV -oN nmap'

# ── Dotfiles tools ────────────────────────────────────────────────────────────
alias vscode-ext='~/.local/bin/vscode-ext'
alias claude-clean='~/.local/bin/claude-clean'

{{ if .is_wsl -}}
# ── WSL-specific ──────────────────────────────────────────────────────────────
alias pbcopy='clip.exe'
alias pbpaste='powershell.exe -command "Get-Clipboard"'
{{ end -}}
