# ~/.zshrc — managed by chezmoi
# Machine: {{ .chezmoi.hostname }} | User: {{ .chezmoi.username }}
# Template rendered by chezmoi — edit source at home/dot_zshrc.tmpl

# ── Performance: skip redundant compinit from system ─────────────────────────
skip_global_compinit=1

# ── mise activation (must be near top) ───────────────────────────────────────
if command -v mise &>/dev/null; then
  eval "$(mise activate zsh)"
fi

# ── Tier 3: Development toolchain env vars ────────────────────────────────────
# JAVA_HOME: auto-set by `mise activate` — no explicit setting needed
# Go: GOROOT auto-set by mise; GOPATH/GOBIN set here for conventional layout
export GOPATH="${HOME}/go"
export GOBIN="${HOME}/go/bin"
# Rust: mise activate puts ~/.cargo/bin on PATH; explicit homes for tools that query them
export CARGO_HOME="${HOME}/.cargo"
export RUSTUP_HOME="${HOME}/.rustup"
# Node: predictable global prefix for `npm install -g`
export NPM_CONFIG_PREFIX="${HOME}/.npm-global"
# Maven: cap JVM heap for builds (preserve caller-set value)
export MAVEN_OPTS="${MAVEN_OPTS:--Xmx1024m}"

# ── Path additions ────────────────────────────────────────────────────────────
typeset -U path  # deduplicate PATH
path=(
  "$HOME/.local/bin"
  "${CARGO_HOME}/bin"
  "${GOBIN}"
  "${NPM_CONFIG_PREFIX}/bin"
  $path
)

# ── History ───────────────────────────────────────────────────────────────────
HISTFILE="${HOME}/.cache/zsh/history"
mkdir -p "$(dirname "${HISTFILE}")"
HISTSIZE=50000
SAVEHIST=50000
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE
setopt SHARE_HISTORY
setopt EXTENDED_HISTORY

# ── Completion system ─────────────────────────────────────────────────────────
autoload -Uz compinit
compinit -d "${HOME}/.cache/zsh/zcompdump-${ZSH_VERSION}"

# carapace — universal completions
if command -v carapace &>/dev/null; then
  source <(carapace _carapace zsh)
fi

# ── Zsh plugins ───────────────────────────────────────────────────────────────
ZSH_PLUGIN_DIR="${HOME}/.local/share/zsh/plugins"

_load_plugin() {
  local plugin_dir="${ZSH_PLUGIN_DIR}/$1"
  local plugin_file="${plugin_dir}/$2"
  [[ -f "${plugin_file}" ]] && source "${plugin_file}"
}

_load_plugin "zsh-autosuggestions"    "zsh-autosuggestions.zsh"
_load_plugin "zsh-syntax-highlighting" "zsh-syntax-highlighting.zsh"
_load_plugin "fzf-tab"                "fzf-tab.plugin.zsh"

# ── fzf-tab configuration ─────────────────────────────────────────────────────
zstyle ':completion:*:git-checkout:*' sort false
zstyle ':completion:*:descriptions'  format '[%d]'
zstyle ':completion:*'               list-colors "${(s.:.)LS_COLORS}"
zstyle ':completion:*'               verbose yes
zstyle ':completion:*'               group-name ''
zstyle ':fzf-tab:complete:cd:*'      fzf-preview 'eza -1 --color=always $realpath'
zstyle ':fzf-tab:*'                  switch-group ',' '.'
{{ if .is_wsl -}}
# WSL: disable tmux popup (not supported in all WSL terminals)
zstyle ':fzf-tab:*'                  fzf-command fzf
{{ else -}}
zstyle ':fzf-tab:*'                  fzf-command ftb-tmux-popup
{{ end -}}
zstyle ':fzf-tab:*'                  continuous-trigger '/'

# ── Prompt: starship ──────────────────────────────────────────────────────────
if command -v starship &>/dev/null; then
  eval "$(starship init zsh)"
fi

# ── History: atuin ────────────────────────────────────────────────────────────
if command -v atuin &>/dev/null; then
  eval "$(atuin init zsh)"
fi

# ── Navigation: zoxide ────────────────────────────────────────────────────────
if command -v zoxide &>/dev/null; then
  eval "$(zoxide init zsh)"
fi

# ── Directory env: direnv ────────────────────────────────────────────────────
if command -v direnv &>/dev/null; then
  eval "$(direnv hook zsh)"
fi

# ── FZF ───────────────────────────────────────────────────────────────────────
if command -v fzf &>/dev/null; then
  source <(fzf --zsh)
fi
export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
export FZF_DEFAULT_OPTS='--height 40% --layout=reverse --border --info=inline'

# ── Key bindings ──────────────────────────────────────────────────────────────
bindkey '^a'    beginning-of-line
bindkey '^e'    autosuggest-accept      # accept zsh-autosuggestion
bindkey '^w'    autosuggest-execute     # execute zsh-autosuggestion
bindkey '^u'    autosuggest-toggle      # toggle zsh-autosuggestion
bindkey '^L'    vi-forward-word
bindkey '^k'    up-line-or-search
bindkey '^j'    down-line-or-search
bindkey '^W'    backward-kill-word

# Home/End keys (multiple terminal variants)
bindkey '^[[H'  beginning-of-line    # Home (standard)
bindkey '^[[1~' beginning-of-line    # Home (alternate)
bindkey '^[[F'  end-of-line          # End (standard)
bindkey '^[[4~' end-of-line          # End (alternate)

# Ctrl+Arrow keys for word navigation (multiple terminal variants)
bindkey '^[[1;5C' forward-word       # Ctrl+Right (standard)
bindkey '^[[1;5D' backward-word      # Ctrl+Left (standard)
bindkey '^[^[[C'  forward-word       # Ctrl+Right (alternate)
bindkey '^[^[[D'  backward-word      # Ctrl+Left (alternate)

# ── Aliases (sourced from ~/.config/shell/aliases.sh) ────────────────────────
[[ -f "${HOME}/.config/shell/aliases.sh" ]] && source "${HOME}/.config/shell/aliases.sh"

# ── VSCode shell integration ───────────────────────────────────────────────────
[[ "$TERM_PROGRAM" == "vscode" ]] && . "$(code --locate-shell-integration-path zsh 2>/dev/null)" 2>/dev/null || true

{{ if .is_wsl -}}
# ── WSL-specific configuration ────────────────────────────────────────────────
export BROWSER='wslview'
export DISPLAY="${DISPLAY:-$(ip route | awk '/^default/{print $3}'):0}"
{{ end -}}

# ── GPG & SSH agent ───────────────────────────────────────────────────────────
export GPG_TTY="${GPG_TTY:-$(tty 2>/dev/null)}"
export GNUPGHOME="${HOME}/.gnupg"
if [[ -z "${SSH_AUTH_SOCK:-}" ]] && command -v gpgconf &>/dev/null; then
  export SSH_AUTH_SOCK="$(gpgconf --list-dirs agent-ssh-socket 2>/dev/null || true)"
fi

# ── API keys (chezmoi-managed encrypted files) ────────────────────────────────
# Files are decrypted by `chezmoi apply` into ~/.config/api-keys/
# To add a new key: chezmoi add --encrypt ~/.config/api-keys/<name>
[[ -f "${HOME}/.config/api-keys/tavily" ]] && export TAVILY_API_KEY="$(< "${HOME}/.config/api-keys/tavily")"
[[ -f "${HOME}/.config/api-keys/morph"  ]] && export MORPH_API_KEY="$(< "${HOME}/.config/api-keys/morph")"

# ── KUBECONFIG ────────────────────────────────────────────────────────────────
export KUBECONFIG="${HOME}/.kube/config"

# ── Shell functions ───────────────────────────────────────────────────────────
# Load shell function files managed by chezmoi (~/.local/share/shell-functions/)
# Zsh uses history-tools-zsh.sh; history-tools.sh is bash-specific.
_shell_func_dir="${HOME}/.local/share/shell-functions"
if [[ -d "${_shell_func_dir}" ]]; then
  for _func_file in "${_shell_func_dir}"/*.sh; do
    [[ "${_func_file}" == *"/history-tools.sh" ]] && continue
    [[ -f "${_func_file}" ]] && source "${_func_file}"
  done
fi
unset _shell_func_dir _func_file

set +u
